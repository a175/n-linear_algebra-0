% numberedproof.sty
% This provides the following:
% a. A theorem style for amsthm: numberedproof
% b. Commands to refer proof and theorem each other.
%
% Usuage of a.
% 1. Use the package amsthm, as
%     \usepackage{amsthm}
%    in your preamble.
% 2. Define your proof emvionment with the theorem style numberedproof, as
%     \theoremstyle{numberedproof}
%     \newtheorem{nproof}{Proof}
%    in your preamble.
%
% Usuage of b.
% 1. Use the pakcage cleveref, as
%     \usepackage{cleveref}
%    in your preamble.
% 2. Define your numbered proof environment:
% 3. Define your refered proof environment:
%     \newnumberedproof{name of referered proof}{name of numbered proof}
% 4. Put the following soon after begining some theore menvironment: 
%     \provelater{somelabel}
%    Also write its proof with the following:
%     \begin{name of referered proof}{somelabel}
% 4'. If you have items in your theorem and
%        you want to give proof for each item, then
%     put the following soon after begining some theore menvironment: 
%        \provelater*{somelabelT}
%     put the following soon after begining some theore menvironment: 
%        \provelater**{somelabelT}
%     Also put the following soon in some item: 
%        \provelater*{somelabelI}
%     Write its proof with the following:
%        \begin{name of referered proof*}{somelabelT}{somelabelI}
% 5. If you want to change the message used in each theorem, then
%    overwrite the command \callbackToAnnounceProveLater, as 
%    \renewcommand{\callbackToAnnounceProveLater}[1]{%
%     \marginpar{Proof is \cref{#1}.}%
%    }
% 6. If you want to change the message used in each item, then
%    overwrite the command \callbackToAnnounceProveEachItemLater, as 
%    \renewcommand{\callbackToAnnounceProveEachItemLater}[1]{%
%     \marginpar{Proof is \Cref{#1}.}%
%    }
% 6'. If you donot want to show any in each item, then
%    overwrite the command \callbackToAnnounceProveEachItemLater, as 
%    \renewcommand{\callbackToAnnounceProveEachItemLater}[1]{}
%
%
%
%

\def\th@numberedproof{\pushQED{\qed}	%
  \thm@headfont{\itshape}%
  \normalfont % body font
  \thm@preskip\topsep \divide\thm@preskip\tw@%
  \thm@postskip\thm@preskip%
}
%
\def\th@japanesenumberedproof{\pushQED{\qed}	%
  \normalfont % body font
  \thm@preskip\topsep \divide\thm@preskip\tw@%
  \thm@postskip\thm@preskip%
}

\@ifundefined{@popedqedthm@defined@nu@}{
  \newcommand{\@popedqedthm@defined@nu@}{Defined}
  \let\nous@old@endtheorem\@endtheorem
  \def\@endtheorem{\popQED\nous@old@endtheorem}
}{}
%\let\nous@old@endtheorem\@endtheorem
%\def\@endtheorem{\popQED\nous@old@endtheorem}
%
%
\newcommand{\nu@numberedproof@varname@prooflabellist}[1]{nu@list@prooflabel@#1}
\newcommand{\nu@numberedproof@create@new@prooflabellist}[1]{\expandafter\def\csname \nu@numberedproof@varname@prooflabellist{#1}\endcsname{}}
\newcommand{\nu@numberedproof@append@prooflabellist}[2]{%
  \@ifundefined{\nu@numberedproof@varname@prooflabellist{#1}}{\nu@numberedproof@create@new@prooflabellist{#1}}{}
  \def\nu@list@prooflabel@oldlist{\csname \nu@numberedproof@varname@prooflabellist{#1}\endcsname}\let\nu@list@prooflabel@temp\nu@list@prooflabel@oldlist\global\expandafter\edef\csname \nu@numberedproof@varname@prooflabellist{#1}\endcsname{\nu@list@prooflabel@temp,#2}}
\newcommand{\nu@numberedproof@prooflabellist}[1]{\csname \nu@numberedproof@varname@prooflabellist{#1}\endcsname}

\newcommand{\nu@numberedproof@label@S}[1]{%
  \makebox{}%
  \label{nu@statement@#1}%
  \def\nu@numberedproof@statementlabel{#1}%
  \@ifundefined{\nu@numberedproof@varname@prooflabellist{#1}}{}{\callbackToAnnounceProveLater{\nu@numberedproof@prooflabellist{#1}}}
%   \immediate\write\@auxout{\string\nu@numberedproof@create@new@prooflabellist{#1}}%
}
\newcommand{\nu@numberedproof@prove@this@later}[1]{\makebox{}%
  \nu@numberedproof@label@S{#1}
  \immediate\write\@auxout{\string\nu@numberedproof@append@prooflabellist{#1}{nu@proof@#1}}%
}
\newcommand{\nu@numberedproof@prove@item@later}[1]{\makebox{}%
  \label{nu@statement@\nu@numberedproof@statementlabel:item@#1}%
  \immediate\write\@auxout{\string\nu@numberedproof@append@prooflabellist{\nu@numberedproof@statementlabel}{nu@proof@\nu@numberedproof@statementlabel:item@#1}}%
\callbackToAnnounceProveEachItemLater{nu@proof@\nu@numberedproof@statementlabel:item@#1}%  
}
\newcommand{\nu@numberedproof@prove@each@later}{\@ifstar{\nu@numberedproof@label@S}{\nu@numberedproof@prove@item@later}}

\newcommand{\provelater}{\@ifstar{\nu@numberedproof@prove@each@later}{\nu@numberedproof@prove@this@later}}

\newcommand{\newnumberedproof}[2]{%
  \newenvironment{#1}[1]{%
    \begin{#2}[\callbackToAnnounceTheoremProvedHere{nu@statement@##1}]%
      \label{nu@proof@##1}%
  }{\end{#2}}
  \newenvironment{#1*}[2]{%
    \begin{#2}[\callbackToAnnounceTheoremItemProvedHere{nu@statement@##1}{nu@statement@##1:item@##2}]%
      \label{nu@proof@##1:item@##2}%
  }{\end{#2}}
}

\newcommand{\callbackToAnnounceTheoremProvedHere}[1]{%
  \Cref{#1}%
}
\newcommand{\callbackToAnnounceTheoremItemProvedHere}[2]{%
  \Cref{#1} -- \Cref{#2}%
}
\newcommand{\callbackToAnnounceProveLater}[1]{%
  \marginpar{We will show this later in \cref{#1}.}%
}

\newcommand{\callbackToAnnounceProveEachItemLater}[1]{%
  \marginpar{We will show this later in \cref{#1}.}%
}
